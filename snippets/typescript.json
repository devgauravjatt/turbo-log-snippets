{
  "Turbo Log": {
    "prefix": "tlog",
    "body": ["console.log(\"🚀 ~ ${1:value}:\", ${1:value});", "$0"],
    "description": "console.log with a 🚀 marker (type the variable once, it fills both the label and the value)"
  },
  "Turbo Error": {
    "prefix": "terr",
    "body": ["console.error(\"🚀 ~ ${1:value}:\", ${1:value});", "$0"],
    "description": "console.error with a 🚀 marker"
  },
  "Turbo Warn": {
    "prefix": "twarn",
    "body": ["console.warn(\"🚀 ~ ${1:value}:\", ${1:value});", "$0"],
    "description": "console.warn with a 🚀 marker"
  },
  "Turbo Info": {
    "prefix": "tinfo",
    "body": ["console.info(\"🚀 ~ ${1:value}:\", ${1:value});", "$0"],
    "description": "console.info with a 🚀 marker"
  },
  "Turbo Debug": {
    "prefix": "tdebug",
    "body": ["console.debug(\"🚀 ~ ${1:value}:\", ${1:value});", "$0"],
    "description": "console.debug with a 🚀 marker"
  },
  "Turbo Table": {
    "prefix": "ttable",
    "body": ["console.table(${1:value});", "$0"],
    "description": "console.table for the given value"
  }
}
